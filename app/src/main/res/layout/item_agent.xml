<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="12dp"
    android:layout_marginEnd="12dp"
    android:layout_marginBottom="8dp"
    app:cardCornerRadius="10dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Agent name + status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvAgentName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Phone1"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/white" />

            <TextView
                android:id="@+id/tvAgentStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="активен"
                android:textSize="13sp"
                android:textColor="@color/color_start" />

        </LinearLayout>

        <!-- Row of Start / Stop buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnStartAgent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Старт"
                android:textSize="13sp"
                android:backgroundTint="@color/color_start"
                android:textColor="@android:color/white" />

            <Button
                android:id="@+id/btnStopAgent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:text="Остановить"
                android:textSize="13sp"
                android:backgroundTint="@color/color_stop"
                android:textColor="@android:color/white" />

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/color_divider"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvSim1Status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIM1: —"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:fontFamily="monospace"
            android:layout_marginBottom="3dp" />

        <TextView
            android:id="@+id/tvSim2Status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="SIM2: —"
            android:textSize="13sp"
            android:textColor="@android:color/white"
            android:fontFamily="monospace"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tvLastSeen"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Активность: —"
            android:textSize="11sp"
            android:textColor="#B0B0B0"
            android:fontFamily="monospace" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
