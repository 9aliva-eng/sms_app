<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Phone name -->
        <TextView
            android:id="@+id/tvPhoneName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Телефон: Phone1"
            android:textSize="14sp"
            android:textColor="@color/color_on_surface_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Status indicator row -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <View
                android:id="@+id/indicatorDot"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:background="@drawable/dot_red"
                android:layout_marginEnd="10dp" />

            <TextView
                android:id="@+id/tvStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Остановлено"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/color_on_surface" />

        </LinearLayout>

        <!-- Sent counter -->
        <TextView
            android:id="@+id/tvSentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Отправлено сегодня: 0"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/color_primary"
            android:layout_marginBottom="8dp" />

        <!-- Per-SIM counters -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="24dp">

            <TextView
                android:id="@+id/tvSim1Sent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SIM1: 0 СМС"
                android:textSize="14sp"
                android:textColor="@color/color_on_surface_secondary"
                android:gravity="center" />

            <TextView
                android:id="@+id/tvSim2Sent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="SIM2: 0 СМС"
                android:textSize="14sp"
                android:textColor="@color/color_on_surface_secondary"
                android:gravity="center" />
        </LinearLayout>

        <!-- Start / Stop button -->
        <Button
            android:id="@+id/btnStartStop"
            android:layout_width="200dp"
            android:layout_height="64dp"
            android:text="СТАРТ"
            android:textSize="20sp"
            android:textColor="@android:color/white"
            android:backgroundTint="@color/color_start"
            android:layout_marginBottom="32dp" />

        <!-- Reset stats button -->
        <Button
            android:id="@+id/btnResetStats"
            android:layout_width="200dp"
            android:layout_height="48dp"
            android:text="Сбросить статистику"
            android:textSize="14sp"
            android:layout_marginBottom="24dp" />

        <!-- SIM mode selector card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Режим SIM"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/color_on_surface_secondary"
                    android:layout_marginBottom="8dp" />

                <RadioGroup
                    android:id="@+id/rgSimMode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <RadioButton
                        android:id="@+id/rbSimAuto"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="АВТО"
                        android:textSize="14sp"
                        android:layout_marginEnd="12dp" />

                    <RadioButton
                        android:id="@+id/rbSim1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM1"
                        android:textSize="14sp"
                        android:layout_marginEnd="12dp" />

                    <RadioButton
                        android:id="@+id/rbSim2"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="SIM2"
                        android:textSize="14sp" />

                </RadioGroup>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Info card -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Режим АГЕНТ"
                    android:textSize="13sp"
                    android:textColor="@color/color_on_surface_secondary" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Нажмите СТАРТ — приложение будет работать в фоне.\nМожно заблокировать экран."
                    android:textSize="12sp"
                    android:textColor="@color/color_on_surface_secondary"
                    android:layout_marginTop="4dp" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>
</ScrollView>
